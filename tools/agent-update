#!/usr/bin/env python3
"""
agent-update <done|blocked|testing|active|review> [note]

Call this from any agent session to update agents.csv.
Auto-detects the current tmux session name.

If no note is given on the command line, opens an nvim popup
(via tmux display-popup) for multiline editing.
"""
import csv, subprocess, sys, os, tempfile
from datetime import datetime

AGENT_FILE = os.path.expanduser("~/notes/work_notes/sprints/agents.csv")
AGENT_LOG  = os.path.expanduser("~/notes/work_notes/sprints/agent-log.md")

def main():
    if len(sys.argv) < 2 or sys.argv[1] not in ('done', 'blocked', 'testing', 'active', 'review'):
        print("Usage: agent-update <done|blocked|testing|active|review> [note]")
        sys.exit(1)

    status = sys.argv[1]

    if len(sys.argv) > 2:
        note = ' '.join(sys.argv[2:])
    else:
        # Open nvim in a tmux popup for multiline note editing
        tmp = tempfile.NamedTemporaryFile(suffix='.md', prefix='agent-note-', delete=False)
        tmp.close()
        try:
            subprocess.run(
                ["tmux", "display-popup", "-E", "-w", "80%", "-h", "60%",
                 "nvim", tmp.name],
                check=True
            )
            with open(tmp.name) as f:
                note = f.read().strip()
        finally:
            os.unlink(tmp.name)

        if not note:
            print("Aborted — empty note.")
            sys.exit(0)

    # Detect current tmux session
    try:
        session = subprocess.check_output(
            ["tmux", "display-message", "-p", "#S"],
            stderr=subprocess.DEVNULL, text=True
        ).strip()
    except Exception:
        print("ERROR: could not detect tmux session name")
        sys.exit(1)

    if not session:
        print("ERROR: empty session name")
        sys.exit(1)

    # Update agents.csv
    rows = []
    found = False
    with open(AGENT_FILE) as f:
        for row in csv.reader(f):
            if len(row) > 3 and row[3] == session:
                row[0] = status
                found = True
            rows.append(row)

    if not found:
        print(f"WARNING: session '{session}' not found in agents.csv — not tracked?")
        sys.exit(1)

    with open(AGENT_FILE, 'w', newline='') as f:
        csv.writer(f).writerows(rows)

    # Append to log
    today = datetime.now().strftime('%Y-%m-%d')
    with open(AGENT_LOG, 'a') as f:
        f.write(f"- [{today}] {session}: {note}\n")

    print(f"✓ {session} → {status}")

if __name__ == '__main__':
    main()
